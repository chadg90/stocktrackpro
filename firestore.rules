rules_version = '2';
// Plant module + legacy/trialing company access + web onboarding claim
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function profileExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }
    
    function getProfile() {
      return profileExists()
        ? get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data
        : null;
    }
    
    function isAdmin() {
      return profileExists() && getProfile() != null && getProfile().role == 'admin';
    }
    
    function isManager() {
      return profileExists() && getProfile() != null &&
        (getProfile().role == 'manager' || getProfile().role == 'Manager');
    }

    function isManagerOrAdmin() {
      return isAdmin() || isManager();
    }

    function plantInspectionOwnedByUser(inspectionId) {
      return exists(/databases/$(database)/documents/plant_inspections/$(inspectionId)) &&
        get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.company_id == userCompanyId() &&
        get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.submitted_by == request.auth.uid;
    }
    
    function userCompanyId() {
      return (profileExists() && getProfile().company_id != null)
        ? getProfile().company_id
        : '__NO_COMPANY__';
    }
    
    function companyExists(companyId) {
      return companyId != null && exists(/databases/$(database)/documents/companies/$(companyId));
    }
    
    // Logic: Check if the COMPANY is active, not the individual user
    function isCompanyActive() {
      let companyData = get(/databases/$(database)/documents/companies/$(userCompanyId())).data;
      return profileExists() &&
        companyExists(userCompanyId()) &&
        (
          companyData.get('legacy', false) == true ||
          companyData.subscription_status == 'active' ||
          companyData.subscription_status == 'trial' ||
          companyData.subscription_status == 'trialing'
        );
    }

    // Custom claims (synced by Cloud Functions). Prefer token when present; legacy uses profile + company reads.
    function tokenCompanyMatches(resourceCompanyId) {
      return request.auth != null &&
        request.auth.token.companyId != null &&
        request.auth.token.companyId == resourceCompanyId;
    }

    function tokenSubscriptionActive() {
      return request.auth.token.subscriptionStatus == 'active' ||
        request.auth.token.subscriptionStatus == 'trial' ||
        request.auth.token.subscriptionStatus == 'trialing';
    }

    function tokenTenantOk(resourceCompanyId) {
      return isSignedIn() &&
        tokenCompanyMatches(resourceCompanyId) &&
        tokenSubscriptionActive();
    }

    // Prefer custom claims when present (fast path). Fall back to profile + company docs so
    // brand-new trial signups work before claims sync / ID token refresh completes.
    function legacyTenantOk(resourceCompanyId) {
      return userCompanyId() == resourceCompanyId && isCompanyActive();
    }

    // Admins still reach all docs via GLOBAL ADMIN OVERRIDE match /{path=**} below.
    function vehicleInspectionTenantOk(resourceCompanyId) {
      return tokenTenantOk(resourceCompanyId) || legacyTenantOk(resourceCompanyId);
    }
    
    // ============================================
    // PROFILES
    // ============================================
    // Users cannot grant themselves a higher role or join a company by editing
    // profile: role/company are set at invite accept (callable) or by admin.
    function profileSelfUpdateAllowed(userId) {
      return request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.company_id == resource.data.company_id &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'expoPushToken',
            'pushTokenUpdatedAt',
            'display_name',
            'photo_url',
            'phone',
            'updated_at',
            'firstName',
            'lastName',
            'name',
            'app_platform',
            'app_version',
            'app_build',
            'app_runtime_version',
            'app_ota_label',
            'app_ota_update_id',
            'app_ota_channel',
            'app_last_seen_at',
            'last_login',
            'inspector_job_title',
            'inspector_address',
            'qualification_name',
            'qualification_number',
            'qualification_expiry_date',
            'qualification_issuing_body',
            'employment_status',
            'inspector_employer_name',
            'inspector_employer_address'
          ]);
    }

    // Web onboarding only: creator of a new company may claim manager on that company once.
    // Cannot join someone else's company or escalate an existing role.
    function profileOnboardingClaim(userId) {
      return request.auth.uid == userId &&
        resource.data.company_id == null &&
        (!('role' in resource.data) || resource.data.role == null || resource.data.role == 'user') &&
        request.resource.data.role == 'manager' &&
        request.resource.data.company_id is string &&
        companyExists(request.resource.data.company_id) &&
        get(/databases/$(database)/documents/companies/$(request.resource.data.company_id)).data.created_by == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['company_id', 'role', 'updated_at', 'company_name']);
    }

    function profileManagerUpdateOk() {
      return isManager() &&
        userCompanyId() == resource.data.company_id &&
        request.resource.data.company_id == resource.data.company_id &&
        (request.resource.data.role == 'admin' ? isAdmin() : true);
    }

    match /profiles/{userId} {
      // Users can read their own profile
      // Admins can read all profiles
      // Any authenticated user can read profiles in their company
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        resource.data.company_id == userCompanyId()
      );
      
      // Self-serve create: unprivileged profile only; companies come from web/admin + invites.
      // Admins can create any profile.
      // role may be omitted, null, or 'user' until company step (web onboarding).
      allow create: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          (!('role' in request.resource.data) ||
            request.resource.data.role == null ||
            request.resource.data.role == 'user') &&
          (!('company_id' in request.resource.data) || request.resource.data.company_id == null)
        ) ||
        isAdmin()
      );
      
      // Users cannot change their own role or company_id except onboarding claim;
      // managers cannot promote to admin.
      allow update: if isSignedIn() && (
        isAdmin() ||
        profileSelfUpdateAllowed(userId) ||
        profileOnboardingClaim(userId) ||
        profileManagerUpdateOk()
      );
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // ============================================
    // ACCESS CODES (deprecated — use email invites; collection may remain for data migration)
    // ============================================
    match /access_codes/{codeId} {
      allow read, write: if false;
    }

    // ============================================
    // COMPANIES
    // ============================================
    match /companies/{companyId} {
      // Users in the company can read their company
      // Admins can read any company
      // Creator can read a company (legacy / tools that still set created_by)
      allow read: if isSignedIn() && (
        userCompanyId() == companyId || 
        isAdmin() ||
        resource.data.created_by == request.auth.uid
      );
      
      // Web onboarding creates a company with created_by = uid; mobile self-serve company signup
      // is removed in the app. Admins can create for support flows.
      allow create: if isSignedIn() && (
        isAdmin() ||
        request.resource.data.created_by == request.auth.uid
      );
      
      // Only managers and admins can update companies
      allow update: if isSignedIn() && (isAdmin() || (isManager() && userCompanyId() == companyId));
      
      // Companies should not be deleted (archive instead)
      allow delete: if false;
    }

    // ============================================
    // TOOLS
    // ============================================
    match /tools/{toolId} {
      allow read: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
      allow create: if isSignedIn() && userCompanyId() == request.resource.data.company_id && isCompanyActive();
      allow update: if isSignedIn() &&
        userCompanyId() == request.resource.data.company_id &&
        request.resource.data.company_id == resource.data.company_id &&
        isCompanyActive();
      allow delete: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
    }

    // ============================================
    // LOCATIONS
    // ============================================
    match /locations/{locationId} {
      allow read: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
      allow create: if isSignedIn() && (
        (isManager() && userCompanyId() == request.resource.data.company_id && isCompanyActive()) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        (
          isManager() &&
          userCompanyId() == request.resource.data.company_id &&
          request.resource.data.company_id == resource.data.company_id &&
          isCompanyActive()
        ) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        (isManager() && userCompanyId() == resource.data.company_id && isCompanyActive()) ||
        isAdmin()
      );
    }

    // ============================================
    // TOOL HISTORY
    // ============================================
    match /tool_history/{historyId} {
      allow read: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
      allow create: if isSignedIn() && userCompanyId() == request.resource.data.company_id && isCompanyActive();
      // History is immutable - only admins can modify/delete
      allow update, delete: if isAdmin();
    }

    // ============================================
    // VEHICLES
    // ============================================
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && vehicleInspectionTenantOk(resource.data.company_id);
      allow create: if isSignedIn() && vehicleInspectionTenantOk(request.resource.data.company_id);
      allow update: if isSignedIn() &&
        request.resource.data.company_id == resource.data.company_id &&
        vehicleInspectionTenantOk(resource.data.company_id);
      allow delete: if isSignedIn() && vehicleInspectionTenantOk(resource.data.company_id);
    }

    // ============================================
    // VEHICLE INSPECTIONS
    // ============================================
    match /vehicle_inspections/{inspectionId} {
      allow read: if isSignedIn() && vehicleInspectionTenantOk(resource.data.company_id);
      allow create: if isSignedIn() && vehicleInspectionTenantOk(request.resource.data.company_id);
      // Users can update their own inspections, managers can update any in their company
      allow update: if isSignedIn() && (
        (
          resource.data.inspected_by == request.auth.uid &&
          vehicleInspectionTenantOk(resource.data.company_id)
        ) ||
        (
          isManager() &&
          vehicleInspectionTenantOk(resource.data.company_id)
        ) ||
        isAdmin()
      ) && request.resource.data.company_id == resource.data.company_id;
      allow delete: if isSignedIn() && (
        (isManager() && vehicleInspectionTenantOk(resource.data.company_id)) ||
        isAdmin()
      );
    }

    // ============================================
    // VEHICLE DEFECTS
    // ============================================
    match /vehicle_defects/{defectId} {
      allow read: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
      allow create: if isSignedIn() && userCompanyId() == request.resource.data.company_id && isCompanyActive();
      allow update: if isSignedIn() && (
        (
          isManager() &&
          userCompanyId() == resource.data.company_id &&
          request.resource.data.company_id == resource.data.company_id &&
          isCompanyActive()
        ) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        (isManager() && userCompanyId() == resource.data.company_id && isCompanyActive()) ||
        isAdmin()
      );
    }

    // ============================================
    // VEHICLE DAMAGE REPORTS
    // ============================================
    match /vehicle_damage_reports/{reportId} {
      allow read: if isSignedIn() && userCompanyId() == resource.data.company_id && isCompanyActive();
      allow create: if isSignedIn() && userCompanyId() == request.resource.data.company_id && isCompanyActive();
      allow update: if isSignedIn() && (
        (
          isManager() &&
          userCompanyId() == resource.data.company_id &&
          request.resource.data.company_id == resource.data.company_id &&
          isCompanyActive()
        ) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        (isManager() && userCompanyId() == resource.data.company_id && isCompanyActive()) ||
        isAdmin()
      );
    }

    // ============================================
    // PROMO CODES
    // ============================================
    // List collection = enumerate all codes; only admins. getDoc by id = redeem (signed-in only).
    match /promoCodes/{codeId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['used', 'usedAt', 'usedBy', 'usedCount', 'lastUsedAt', 'lastUsedBy']) &&
          (
            !request.resource.data.hasAny(['usedBy', 'lastUsedBy']) ||
            request.resource.data.usedBy == request.auth.uid ||
            request.resource.data.lastUsedBy == request.auth.uid
          ) &&
          !(resource.data.used == true && request.resource.data.used == false) &&
          (
            request.resource.data.usedCount == null ||
            resource.data.usedCount == null ||
            request.resource.data.usedCount >= resource.data.usedCount
          ) &&
          (
            resource.data.expiresAt == null ||
            resource.data.expiresAt > request.time
          ) &&
          (
            resource.data.maxUses == null ||
            request.resource.data.usedCount == null ||
            request.resource.data.usedCount <= resource.data.maxUses
          ) &&
          (
            request.resource.data.used != true ||
            request.resource.data.usedBy == request.auth.uid
          )
        )
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    // ============================================
    // PROMOTIONAL SUBSCRIPTIONS
    // ============================================
    match /promotionalSubscriptions/{subId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null && resource.data.companyId == userCompanyId()) ||
        isAdmin()
      );
      // Simplified create rule - detailed validation handled in app code within transaction
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        (
          request.resource.data.companyId == null ||
          request.resource.data.companyId == userCompanyId()
        ) &&
        request.resource.data.promoCode != null &&
        exists(/databases/$(database)/documents/promoCodes/$(request.resource.data.promoCode));
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Invites: email match uses auth token email. Some providers omit email in the
    // token; invite rows should still be readable for company/manager. Prefer storing
    // normalised email on the invite; Cloud Functions use Admin SDK to grant access.
    // ============================================
    // INVITES
    // ============================================
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.companyId == userCompanyId() ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      allow create: if isSignedIn() && isManagerOrAdmin() &&
        request.resource.data.companyId == userCompanyId();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isManager() && resource.data.companyId == userCompanyId())
      );
      allow delete: if isSignedIn() && (
        isAdmin() ||
        (isManager() && resource.data.companyId == userCompanyId())
      );
    }

    // ============================================
    // APP CONFIG (for version checking)
    // ============================================
    match /app_config/{configId} {
      // Anyone can read app config (needed for update checks before login)
      allow read: if true;
      // Only admins can write app config
      allow write: if isAdmin();
    }

    // ============================================
    // NOTIFICATION LOGS (for debugging/audit)
    // ============================================
    match /notification_logs/{logId} {
      allow read: if isAdmin();
      // Only Cloud Functions can write (they bypass security rules)
      allow write: if false;
    }

    // ============================================
    // PLANT MACHINES COLLECTION
    // ============================================

    function hasPlantModule() {
      let companyData = get(/databases/$(database)/documents/companies/$(userCompanyId())).data;
      // Legacy customers: Plant module included without plant Stripe subscription
      return companyData.get('legacy', false) == true ||
        (isCompanyActive() && companyData.get('has_plant_module', false) == true);
    }

    function canAccessPlant() {
      return isSignedIn() && hasPlantModule() &&
        (isManagerOrAdmin() || getProfile().get('can_access_plant_module', false) == true);
    }

    match /plant_machines/{machineId} {
      // Read: any user with plant access in same company
      allow read: if canAccessPlant() &&
        resource.data.company_id == userCompanyId();

      // Create: managers/admins only
      allow create: if isSignedIn() && isManagerOrAdmin() && hasPlantModule() &&
        request.resource.data.company_id == userCompanyId();

      // Update: managers/admins only (status, details)
      allow update: if isSignedIn() && isManagerOrAdmin() && hasPlantModule() &&
        resource.data.company_id == userCompanyId();

      // No hard deletes — archive with is_active: false
      allow delete: if false;
    }

    // ============================================
    // PLANT INSPECTIONS COLLECTION
    // ============================================

    match /plant_inspections/{inspectionId} {
      allow create: if canAccessPlant() &&
        request.resource.data.company_id == userCompanyId() &&
        request.resource.data.submitted_by == request.auth.uid &&
        request.resource.data.locked == false;

      allow read: if canAccessPlant() &&
        resource.data.company_id == userCompanyId();

      // Submitter locks their own draft; managers may update locked records (amendments etc.)
      allow update: if isSignedIn() && hasPlantModule() &&
        resource.data.company_id == userCompanyId() &&
        (
          (resource.data.submitted_by == request.auth.uid &&
            resource.data.locked == false &&
            request.resource.data.locked == true) ||
          (isManagerOrAdmin() && resource.data.locked == true)
        );

      allow delete: if false;

      match /checklist_items/{itemId} {
        allow read: if canAccessPlant() &&
          get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.company_id == userCompanyId();
        allow create: if canAccessPlant() &&
          request.resource.data.inspection_id == inspectionId &&
          plantInspectionOwnedByUser(inspectionId) &&
          get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.locked == false;
        allow update, delete: if false;
      }

      match /parts_used/{partId} {
        allow read: if canAccessPlant() &&
          get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.company_id == userCompanyId();
        allow create: if canAccessPlant() &&
          request.resource.data.inspection_id == inspectionId &&
          plantInspectionOwnedByUser(inspectionId) &&
          get(/databases/$(database)/documents/plant_inspections/$(inspectionId)).data.locked == false;
        allow update, delete: if false;
      }
    }

    match /plant_counters/{counterId} {
      allow read: if isManagerOrAdmin() && hasPlantModule();
      allow write: if false;
    }

    match /company_sites/{siteId} {
      allow read: if canAccessPlant() && resource.data.company_id == userCompanyId();
      allow create, update: if isSignedIn() && isManagerOrAdmin() && hasPlantModule() &&
        request.resource.data.company_id == userCompanyId();
      allow delete: if isSignedIn() && isAdmin() && hasPlantModule() &&
        resource.data.company_id == userCompanyId();
    }

    match /plant_parts_library/{partId} {
      allow read: if canAccessPlant() && resource.data.company_id == userCompanyId();
      allow create: if canAccessPlant() &&
        request.resource.data.company_id == userCompanyId() &&
        request.resource.data.created_by == request.auth.uid;
      allow update: if canAccessPlant() &&
        resource.data.company_id == userCompanyId() &&
        request.resource.data.company_id == userCompanyId() &&
        (resource.data.created_by == request.auth.uid || isManagerOrAdmin());
      allow delete: if isSignedIn() && isManagerOrAdmin() && hasPlantModule() &&
        resource.data.company_id == userCompanyId();
    }

    match /plant_saved_addresses/{addressId} {
      allow read: if canAccessPlant() && resource.data.company_id == userCompanyId();
      allow create: if canAccessPlant() &&
        request.resource.data.company_id == userCompanyId() &&
        request.resource.data.created_by == request.auth.uid;
      allow update: if canAccessPlant() &&
        resource.data.company_id == userCompanyId() &&
        request.resource.data.company_id == userCompanyId();
      allow delete: if canAccessPlant() && resource.data.company_id == userCompanyId() &&
        (resource.data.created_by == request.auth.uid || isManagerOrAdmin());
    }

    match /inspection_amendments/{amendmentId} {
      allow read: if canAccessPlant() && resource.data.company_id == userCompanyId();
      allow create: if isSignedIn() && isManagerOrAdmin() && hasPlantModule() &&
        request.resource.data.company_id == userCompanyId();
      allow update, delete: if false;
    }

    // ============================================
    // GLOBAL ADMIN OVERRIDE
    // ============================================
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
