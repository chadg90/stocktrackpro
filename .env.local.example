# Firebase (client – same as app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server only – for webhook/API)
# Paste the full JSON from Firebase Console > Project Settings > Service Accounts > Generate new key
# IMPORTANT: This must be on a single line (no line breaks). Use `cat key.json | jq -c .` to minify.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe API keys
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for the per-vehicle plan
# Create ONE product in Stripe ("Stock Track PRO — Per Vehicle") with TWO recurring prices:
#   - Monthly: £8 GBP, Recurring monthly
#   - Annual:  £84 GBP, Recurring yearly (= £7/mo effective, ~12% saving)
STRIPE_PRICE_PER_VEHICLE=price_...
STRIPE_PRICE_PER_VEHICLE_YEARLY=price_...

# Plant & Machinery module — quantity = slider / machine count at checkout
# Product: Plant & Machinery Module (prod_UWoyF3TdWqK9SR)
# Monthly £12/machine • Yearly £120/machine
STRIPE_PRICE_PLANT_PER_MACHINE=price_1TXlTbHbmFLRZL4BP0KUdoUc
STRIPE_PRICE_PLANT_PER_MACHINE_YEARLY=price_1TXlTcHbmFLRZL4BmoM1aLut

# Optional: Stripe customer portal configuration ID (from Stripe Dashboard > Billing > Customer portal)
STRIPE_PORTAL_CONFIGURATION_ID=

# Website base URL (for Stripe success/cancel redirects). MUST match your live canonical URL, e.g. https://www.stocktrackpro.co.uk
NEXT_PUBLIC_APP_URL=

# Optional: comma-separated verified profile URLs for Organization schema sameAs (e.g. LinkedIn company page)
# NEXT_PUBLIC_ORGANIZATION_SAME_AS=https://www.linkedin.com/company/your-page
